# AI API Gateway Environment Configuration
# Copy this file to .env and update values for production

# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_gateway?sslmode=disable

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# Server Configuration
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=debug

# CORS Configuration
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Email Configuration (for verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sixweisix@gmail.com
SMTP_PASSWORD=matbmbfgmkbncllf
EMAIL_FROM=sixweisix@gmail.com

# Payment Configuration (Stripe)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=http://localhost:3001/payment/success
STRIPE_CANCEL_URL=http://localhost:3001/payment/cancel

# Payment Configuration (Alipay)
# 1. 登录 https://open.alipay.com 创建应用并获取 APP_ID
# 2. 生成 RSA2 密钥对: openssl genrsa -out app_private_key.pem 2048
# 3. 上传公钥到支付宝开放平台，获取支付宝公钥
# 4. 沙箱环境: https://open.alipay.com/develop/sandbox (默认 sandbox=true)
ALIPAY_APP_ID=2021006149650060
ALIPAY_PRIVATE_  # RSA2 私钥内容 (不要换行，用 \n 代替换行)
ALIPAY_PUBLIC_   # 支付宝公钥内容 (同上)
ALIPAY_NOTIFY_URL=https://your-domain.com/v1/recharge/alipay/notify  # 异步通知回调(必须公网可访问)
ALIPAY_RETURN_URL=https://your-domain.com/v1/recharge/alipay/return  # 同步跳转回显
ALIPAY_SANDBOX=true     # 开发阶段用沙箱，上线后改为 false

# Upstream API Keys (for testing, replace with actual keys)
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GOOGLE_API_KEY=xxx

# Admin User (initial admin credentials)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123  # Change immediately after first login

# Security
ALLOW_REGISTRATION=true
REQUIRE_EMAIL_VERIFICATION=false
SESSION_SECURE_COOKIES=false

# Monitoring & Alerts
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=        # BotFather 创建 Bot 后获取的 Token
TELEGRAM_CHAT_ID=          # 接收告警的 Telegram 群组/用户 ID
MONITOR_INTERVAL=5m        # 告警检查间隔 (e.g., 5m, 10m)

# Frontend URLs
FRONTEND_USER_URL=http://localhost:3001
FRONTEND_ADMIN_URL=http://localhost:3000/admin
API_BASE_URL=http://localhost:8080