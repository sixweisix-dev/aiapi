transitai.cloud {
    tls sixweisix@gmail.com

    log {
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
        level INFO
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }

    handle /v1/* {
        request_body max_size 10mb
        reverse_proxy backend:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /xgj/* {
        request_body max_size 10mb
        reverse_proxy backend:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /admin* {
        reverse_proxy frontend_admin:80
    }

    # 带 hash 的静态资源(assets/*.js/css/图片) 1年 immutable 缓存
    @staticAssets path /assets/*
    header @staticAssets Cache-Control "public, max-age=31536000, immutable"

    # index.html 不缓存,保证新版立即生效
    @indexHtml path / /index.html /admin /admin/
    header @indexHtml Cache-Control "no-cache, must-revalidate"

    handle {
        reverse_proxy frontend_user:80
    }
}
